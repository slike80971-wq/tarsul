generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  password          String
  name              String
  avatar            String?
  status            String   @default("غير متصل")
  role              String   @default("مستخدم")
  approvalStatus    String   @default("approved")
  isBlocked         Boolean  @default(false)
  timezone          String   @default("Asia/Riyadh")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  conversations       ConversationMember[]
  messages            Message[]
  channelMembers      ChannelMember[]
  channelMessages     ChannelMessage[]
  createdConversations Conversation[] @relation("ConversationCreator")
  createdChannels      Channel[] @relation("ChannelCreator")
  voiceCallsInitiated VoiceCall[] @relation("CallInitiator")
  voiceCallsReceived  VoiceCall[] @relation("CallReceiver")

  @@index([status])
  @@index([role])
}

model Conversation {
  id          String   @id @default(cuid())
  name        String?
  type        String   @default("خاص")
  status      String   @default("مفتوحة")
  isFavorite  Boolean  @default(false)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User? @relation("ConversationCreator", fields: [createdById], references: [id])
  members    ConversationMember[]
  messages   Message[]
  voiceCalls VoiceCall[]

  @@index([createdById])
}

model ConversationMember {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())
  lastReadAt     DateTime @default(now())
  notifications  Boolean  @default(true)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  type           String   @default("نص")
  fileName       String?
  fileUrl        String?
  fileSize       Int?
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
}

model Channel {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdById String?
  isLocked    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User? @relation("ChannelCreator", fields: [createdById], references: [id])
  members    ChannelMember[]
  messages   ChannelMessage[]
  voiceCalls VoiceCall[]

  @@index([createdById])
}

model ChannelMember {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  role      String   @default("عضو")
  joinedAt  DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
}

model ChannelMessage {
  id        String   @id @default(cuid())
  channelId String
  senderId  String
  content   String
  type      String   @default("نص")
  fileName  String?
  fileUrl   String?
  fileSize  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender  User    @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([channelId])
  @@index([senderId])
}

model VoiceCall {
  id             String   @id @default(cuid())
  callerId       String
  receiverId     String
  conversationId String?
  channelId      String?
  status         String   @default("ringing")
  duration       Int      @default(0)
  createdAt      DateTime @default(now())
  endedAt        DateTime?

  caller       User          @relation("CallInitiator", fields: [callerId], references: [id], onDelete: Cascade)
  receiver     User          @relation("CallReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  channel      Channel?      @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([callerId])
  @@index([receiverId])
  @@index([conversationId])
  @@index([channelId])
}
