// Tarsul - تراسل | Enterprise Encrypted Chat Platform
// Database Schema — PostgreSQL (Supabase / Vercel)

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

  

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ========================
// User Management
// ========================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  avatar       String?              // Profile avatar URL/path
  role         String   @default("member") // admin, manager, member
  department   String?              // e.g., "الإدارة", "تقنية المعلومات", "الموارد البشرية"
  status       String   @default("offline") // online, away, offline, do_not_disturb
  publicKey    String?              // RSA public key (PEM) for E2EE key exchange
  lastSeen     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  sentMessages       Message[]
  channelMemberships ChannelMember[]
  createdChannels    Channel[]    @relation("ChannelCreator")
  dmUser1            DirectMessage[] @relation("DM_User1")
  dmUser2            DirectMessage[] @relation("DM_User2")
  keyPairs           KeyPair[]
  tweets             Tweet[]
  tweetLikes         TweetLike[]
  sessions           Session[]

  @@map("users")
}

// ========================
// Key Management (E2EE)
// ========================

model KeyPair {
  id        String   @id @default(cuid())
  userId    String
  publicKey String              // RSA-OAEP public key (PEM format)
  privateKeyEncrypted String?   // RSA private key encrypted with user's passphrase (stored only if user opts in)
  algorithm String   @default("RSA-OAEP") // Encryption algorithm used
  keySize   Int      @default(2048)
  createdAt DateTime @default(now())
  isActive  Boolean  @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("key_pairs")
}

// ========================
// Channels (Group Conversations / Departments)
// ========================

model Channel {
  id          String   @id @default(cuid())
  name        String                   // Channel name, e.g., "عام", "تقنية المعلومات"
  description String?                  // Channel description
  type        String   @default("channel") // channel, group, department
  icon        String?                  // Channel icon/emoji
  createdBy   String                   // User ID who created the channel
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  members  ChannelMember[]
  messages Message[]
  creator  User @relation("ChannelCreator", fields: [createdBy], references: [id])

  @@map("channels")
}

// ========================
// Channel Memberships
// ========================

model ChannelMember {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  role      String   @default("member") // admin, member
  lastRead  DateTime?                  // Last read message timestamp for unread counts
  joinedAt  DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@map("channel_members")
}

// ========================
// Direct Messages (1-to-1 Conversations)
// ========================

model DirectMessage {
  id        String   @id @default(cuid())
  user1Id   String
  user2Id   String
  lastMessageAt DateTime @default(now())
  createdAt DateTime @default(now())

  user1    User     @relation("DM_User1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2    User     @relation("DM_User2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([user1Id, user2Id])
  @@map("direct_messages")
}

// ========================
// Messages (Encrypted Content)
// ========================

model Message {
  id          String   @id @default(cuid())
  content     String                    // Encrypted message content (AES-GCM ciphertext, base64)
  iv          String?                   // AES-GCM initialization vector (base64)
  senderId    String
  channelId   String?                   // Null for direct messages
  dmId        String?                   // Null for channel messages
  type        String   @default("text") // text, file, system, encrypted, reply
  replyToId   String?                   // ID of the message being replied to
  metadata    String?                   // JSON string for file info, mentions, etc.
  isEdited    Boolean  @default(false)
  isPinned    Boolean  @default(false)
  isDeleted   Boolean  @default(false)  // Soft delete
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  sender  User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  channel Channel?      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  dm      DirectMessage? @relation(fields: [dmId], references: [id], onDelete: Cascade)
  replies Message[]      @relation("MessageReplies")
  replyTo Message?       @relation("MessageReplies", fields: [replyToId], references: [id])

  @@index([channelId])
  @@index([dmId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}

// ========================
// Sessions (Persistent Auth)
// ========================

model Session {
  id        String   @id @default(cuid())
  token     String   @unique              // Session token
  userId    String
  expiresAt DateTime                      // Expiration timestamp
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

// ========================
// Tweets / تغريدات (Corporate Micro-Blog)
// ========================

model Tweet {
  id        String   @id @default(cuid())
  content   String                          // Tweet text content
  senderId  String
  likes     Int      @default(0)            // Like count
  retweets  Int      @default(0)            // Retweet/repost count
  isDeleted Boolean  @default(false)        // Soft delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sender User @relation(fields: [senderId], references: [id], onDelete: Cascade)
  TweetLike TweetLike[]

  @@index([senderId])
  @@index([createdAt])
  @@map("tweets")
}

// ========================
// Tweet Likes
// ========================

model TweetLike {
  id       String @id @default(cuid())
  tweetId  String
  userId   String
  createdAt DateTime @default(now())

  tweet Tweet @relation(fields: [tweetId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tweetId, userId])
  @@map("tweet_likes")
}
